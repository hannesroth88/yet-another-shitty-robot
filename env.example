# Phase 0 prototype config. Copy to .env (cp env.example .env) and tweak.
# All values have defaults in src/config.py, so .env is optional.

# --- Audio ---
# ffmpeg avfoundation audio device index (list: ffmpeg -f avfoundation -list_devices true -i "")
AUDIO_INPUT_DEVICE=1
SAMPLE_RATE=16000
MAX_RECORD_SECONDS=30

# --- STT ---
STT_BACKEND=faster-whisper
# tiny | base | small | medium  (bigger = slower + more accurate)
STT_MODEL=base
STT_COMPUTE_TYPE=int8
STT_LANGUAGE=de

# --- LLM (Ollama) ---
LLM_BACKEND=ollama
OLLAMA_HOST=http://localhost:11434
LLM_MODEL=llama3.2:latest
SYSTEM_PROMPT=Du bist ein knapper, freundlicher Sprachassistent. Antworte immer auf Deutsch und halte deine Antworten kurz und gut vorlesbar. Verwende kein Markdown, keine Listen und keine Emojis.

# --- TTS ---
# say (macOS, zero-dep default for Phase 0) | piper (cross-platform, fleet default)
TTS_BACKEND=say
SAY_VOICE=Anna
PIPER_BIN=piper
PIPER_VOICE=voices/de_DE-thorsten-high.onnx

# --- Voice effect (DSP over any TTS backend) ---
# none | robot
TTS_EFFECT=robot
# Ring modulation: carrier 40-70Hz stays intelligible, higher = more garbled
ROBOT_CARRIER_HZ=55
ROBOT_MIX=0.65
# Tremolo (mechanical pulse); 0 = off
ROBOT_TREMOLO_HZ=0
ROBOT_TREMOLO_DEPTH=0
# Short comb = metallic tin-can resonance; 0 = off
ROBOT_COMB_MS=1.5
ROBOT_COMB_GAIN=0.35
