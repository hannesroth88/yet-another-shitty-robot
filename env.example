# Phase 0 prototype config. Copy to .env (cp env.example .env) and tweak.
# All values have defaults in src/config.py, so .env is optional.

# --- Audio ---
# ffmpeg avfoundation audio device index (list: ffmpeg -f avfoundation -list_devices true -i "")
AUDIO_INPUT_DEVICE=1
SAMPLE_RATE=16000
MAX_RECORD_SECONDS=30

# --- STT ---
STT_BACKEND=faster-whisper
# tiny | base | small | medium  (bigger = slower + more accurate)
STT_MODEL=base
STT_COMPUTE_TYPE=int8
STT_LANGUAGE=de
# Network STT service (STT_BACKEND=http) -- runs on another host (Phase 2 NUC).
STT_HTTP_URL=http://localhost:9000
# Parakeet candidate (STT_BACKEND=parakeet): pip install parakeet-mlx (Mac) or
# nemo_toolkit[asr] (CUDA). English-leaning; benchmark before adopting for German.
PARAKEET_MODEL=mlx-community/parakeet-tdt-0.6b-v2

# --- LLM (Ollama) ---
LLM_BACKEND=ollama
OLLAMA_HOST=http://localhost:11434
LLM_MODEL=llama3.2:latest
# Network LLM (LLM_BACKEND=http) -- point at remote Ollama/llama.cpp/vLLM.
#   Phase 2: flip these to run the model on the Gaming PC GPU, no code change.
LLM_HTTP_URL=http://localhost:11434
LLM_HTTP_FORMAT=ollama        # ollama | openai (llama.cpp --api, vLLM, LM Studio)
# LLM_HTTP_API_KEY=           # bearer token if the endpoint needs one
SYSTEM_PROMPT=Du bist ein knapper, freundlicher Sprachassistent. Antworte immer auf Deutsch und halte deine Antworten kurz und gut vorlesbar. Verwende kein Markdown, keine Listen und keine Emojis.

# --- TTS ---
# say (macOS, zero-dep) | piper (cross-platform) | kokoro (German Martin)
# | qwen3-mlx (Apple Silicon, fast + voice clone) | qwen3 (PyTorch, x86/CUDA)
TTS_BACKEND=say
# Streaming: speak sentence 1 while the LLM writes sentence 2 (first_audio_ms win).
TTS_STREAMING=1
TTS_SENTENCES_PER_CHUNK=1
SAY_VOICE=Anna
PIPER_BIN=piper
PIPER_VOICE=voices/de_DE-thorsten-high.onnx
# Kokoro German "Martin" (ONNX) -- often better German than Piper.
#   pip install kokoro-onnx huggingface_hub && python -m utils.fetch_kokoro
#   then set TTS_BACKEND=kokoro. The robot filter (TTS_EFFECT) still applies.
KOKORO_MODEL=voices/kokoro-martin.onnx
KOKORO_VOICES=voices/voices-martin.npz
KOKORO_VOICE=martin
KOKORO_SPEED=1.0
KOKORO_LANG=de

# Qwen3-TTS — Apple Silicon MLX path (fast + voice clone). TTS_BACKEND=qwen3-mlx
#   pip install mlx-audio
#   Provide a clean mono reference wav + its exact transcript, then warm up:
#   python -m utils.fetch_qwen3_mlx
QWEN3_MLX_MODEL=mlx-community/Qwen3-TTS-12Hz-0.6B-Base-6bit
QWEN3_REF_AUDIO=voices/sample/reference.wav
QWEN3_REF_TEXT_FILE=voices/sample/voice_preview_friendly_small_teaching_robot.txt
# QWEN3_REF_TEXT=   # inline transcript instead of a file (optional)

# Qwen3-TTS — PyTorch/transformers path (qwen-tts package; x86/CUDA fleet hosts)
#   pip install qwen-tts torch  ; then set TTS_BACKEND=qwen3
QWEN3_MODEL=Qwen/Qwen3-TTS-12Hz-0.6B-CustomVoice
QWEN3_DEVICE_MAP=auto
QWEN3_DTYPE=auto
QWEN3_ATTN_IMPLEMENTATION=auto
QWEN3_MODE=custom
QWEN3_LANGUAGE=German
QWEN3_SPEAKER=Ryan
QWEN3_INSTRUCT=
# For cloning mode (QWEN3_MODE=clone):
QWEN3_REF_AUDIO=voices/robot-ref.wav
QWEN3_REF_TEXT=

# --- Voice effect (DSP over any TTS backend) ---
# none | robot   (German comes from the TTS; the robot character is pure DSP)
TTS_EFFECT=robot
# Monotone "robotization" (STFT zero-phase) -- the strongest robot lever, 0..1
ROBOT_PHASE_STRENGTH=0.9
# Robot buzz pitch = sample_rate / hop. Smaller hop = higher/tinier. Tiny=~150.
ROBOT_PHASE_HOP=150
# STFT analysis frame; larger = smoother/cleaner robotization
ROBOT_PHASE_FRAME=2048
# Lowpass on the robotized signal -- removes crackle. Lower = smoother (2800-5000)
ROBOT_PHASE_LOWPASS_HZ=5000
# Formant shift: >1 = smaller/daintier "tiny robot" voice (1.0-1.6)
ROBOT_PHASE_FORMANT=1.4
# Ring modulation (metallic buzz): carrier 30-70Hz, mix 0..1 (0 = off)
ROBOT_CARRIER_HZ=0
ROBOT_MIX=0.0
# Bit-crush (digital grit): bits 4-8 (0=off), rate_div 1=off / 2-4=grittier
ROBOT_BITS=0
ROBOT_RATE_DIV=1
# Tremolo (mechanical pulse); 0 = off
ROBOT_TREMOLO_HZ=16
ROBOT_TREMOLO_DEPTH=0.25
# Short comb = metallic tin-can resonance; 0 = off
ROBOT_COMB_MS=0
ROBOT_COMB_GAIN=0

# --- Control server (Phase 1 HTTP + WebSocket entry point) ---
#   python -m src.server.app  ->  open http://localhost:8010
SERVER_HOST=0.0.0.0
SERVER_PORT=8010
