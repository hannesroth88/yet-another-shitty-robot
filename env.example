# Phase 0 prototype config. Copy to .env (cp env.example .env) and tweak.
# All values have defaults in src/config.py, so .env is optional.

# --- Audio ---
# ffmpeg avfoundation audio device index (list: ffmpeg -f avfoundation -list_devices true -i "")
AUDIO_INPUT_DEVICE=1
SAMPLE_RATE=16000
MAX_RECORD_SECONDS=30

# --- STT ---
STT_BACKEND=parakeet
PARAKEET_MODEL=mlx-community/parakeet-tdt-0.6b-v3
# tiny | base | small | medium  (bigger = slower + more accurate) | large-v3-turbo (best German, optional add-on -- see README)
STT_MODEL=large-v3-turbo
STT_COMPUTE_TYPE=int8
STT_LANGUAGE=de

# --- LLM (Ollama) ---
LLM_BACKEND=ollama
OLLAMA_HOST=http://localhost:11434
LLM_MODEL=gemma4:12b
# Alternatives to benchmark:
# LLM_MODEL=gemma4:e4b          # MoE ~4B active params, fastest, 9.6GB
# LLM_MODEL=gemma4:26b          # MoE 26B/~4B active, best German quality, 18GB
# LLM_MODEL=qwen2.5:14b         # alternative, strong multilingual, 8.5GB
# LLM_MODEL=llama3.2:latest     # old default, 3B
SYSTEM_PROMPT=Du bist Tinker, ein kleiner freundlicher Roboter. Antworte immer auf Deutsch, kurz und leicht vorlesbar. Nutze kein Markdown, keine Listen und keine Emojis. Kein Erwachseneninhalt. Deine Gesprächspartner sind kleine Kinder. Du bist freundlich, neugierig, hilfsbereit und leicht verspielt. Sprich kindgerecht, beantworte Fragen einfach und verständlich und erzähle bei Gelegenheit kleine Witze, Geschichten oder interessante Fakten. Dein Ziel ist es, Kindern Freude zu machen und ihnen zu helfen.

# --- TTS ---
# say (macOS, zero-dep default for Phase 0) | piper (cross-platform, fleet default) | kokoro (best German, optional add-on) | qwen3-mlx (fast + voice cloning, optional add-on) | worker (external TTS server, e.g. for running TTS on a separate machine)
TTS_BACKEND=worker
SAY_VOICE=Anna
PIPER_BIN=piper
PIPER_VOICE=voices/de_DE-thorsten-high.onnx
# Kokoro German "Martin" (ONNX) -- often better German than Piper.
#   pip install kokoro-onnx huggingface_hub && python -m utils.fetch_kokoro
#   then set TTS_BACKEND=kokoro. The robot filter (TTS_EFFECT) still applies.
KOKORO_MODEL=voices/kokoro-martin.onnx
KOKORO_VOICES=voices/voices-martin.npz
KOKORO_VOICE=martin
KOKORO_SPEED=1.0
KOKORO_LANG=de
# Qwen3-TTS on Apple Silicon (MLX) -- fast + clones a reference voice (ICL).
#   pip install mlx-audio ; provide a clean mono ref wav + its transcript.
QWEN3_MLX_MODEL=mlx-community/Qwen3-TTS-12Hz-0.6B-Base-6bit
QWEN3_LANGUAGE=german
QWEN3_REF_AUDIO=voices/sample/voice_preview_friendly_small_teaching_robot.wav
QWEN3_REF_TEXT_FILE=voices/sample/voice_preview_friendly_small_teaching_robot.txt

# --- Voice effect (DSP over any TTS backend) ---
# none | robot   (German comes from the TTS; the robot character is pure DSP)
TTS_EFFECT=none
# Monotone "robotization" (STFT zero-phase) -- the strongest robot lever, 0..1
ROBOT_PHASE_STRENGTH=0.9
# Robot buzz pitch = sample_rate / hop. Smaller hop = higher/tinier. Tiny=~150.
ROBOT_PHASE_HOP=150
# STFT analysis frame; larger = smoother/cleaner robotization
ROBOT_PHASE_FRAME=2048
# Lowpass on the robotized signal -- removes crackle. Lower = smoother (2800-5000)
ROBOT_PHASE_LOWPASS_HZ=5000
# Formant shift: >1 = smaller/daintier "tiny robot" voice (1.0-1.6)
ROBOT_PHASE_FORMANT=1.4
# Ring modulation (metallic buzz): carrier 30-70Hz, mix 0..1 (0 = off)
ROBOT_CARRIER_HZ=0
ROBOT_MIX=0.0
# Bit-crush (digital grit): bits 4-8 (0=off), rate_div 1=off / 2-4=grittier
ROBOT_BITS=0
ROBOT_RATE_DIV=1
# Tremolo (mechanical pulse); 0 = off
ROBOT_TREMOLO_HZ=16
ROBOT_TREMOLO_DEPTH=0.25
# Short comb = metallic tin-can resonance; 0 = off
ROBOT_COMB_MS=0
ROBOT_COMB_GAIN=0

# --- VAD (Voice Activity Detection) ---
# Backend: silero (neural, recommended) | energy (zero-dep fallback)
VAD_BACKEND=silero

# -- Silero VAD (VAD_BACKEND=silero) --
# pip install silero-vad  (pulls torch; already present if you use qwen3-mlx)
# Path to the bundled ONNX model (only used by the legacy ONNX path, not the
# default PyTorch JIT loader -- kept for reference / fleet use).
# VAD_SILERO_MODEL=voices/silero_vad.onnx
# Speech probability threshold (0–1). 0.5 is the Silero default.
# Raise to 0.6–0.7 in noisy environments; lower to 0.4 if words get cut off.
VAD_SILERO_THRESHOLD=0.5
# VAD_SILERO_THRESHOLD=0.7   # noisier room
# VAD_SILERO_THRESHOLD=0.4   # quieter room / sensitive mic

# -- Energy VAD (VAD_BACKEND=energy) --
# Hard RMS floor: frame must exceed this absolute minimum to count as speech.
# VAD_THRESHOLD=0.02
# VAD_THRESHOLD=0.03         # noisier environment
# Adaptive gate: frame must be at least VAD_SNR_RATIO × the estimated noise
# floor (EWMA over silent frames). Raises automatically with ambient noise.
# VAD_SNR_RATIO=2.5
# VAD_SNR_RATIO=3.0          # noisier environment

# -- Shared VAD tuning --
# Consecutive speech frames required before an utterance opens
# (32 ms/frame → 4 frames = ~130 ms onset guard against noise bursts).
# VAD_START_FRAMES=4
# VAD_START_FRAMES=5         # noisier environment
# Trailing silence before the utterance is closed and sent to STT.
# VAD_MIN_SILENCE_MS=800
# Utterances shorter than this are dropped as noise before hitting STT
# (300 ms ≈ shortest meaningful German syllable).
# VAD_MIN_SPEECH_MS=300
# Audio captured before speech onset (keeps word beginnings).
# VAD_PREROLL_MS=300
# VAD_PREROLL_MS=400         # if first syllable is clipped

# Hugging Face Hub (needed to download gated models, e.g. Kokoro, Parakeet)
HF_TOKEN=your_hf_token_here
